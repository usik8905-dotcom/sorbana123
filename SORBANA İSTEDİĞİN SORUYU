            margin-bottom: 20px;
        }

        .search-bar input {
            width: 100%;
            padding: 14px 20px 14px 50px;
            background: rgba(255,255,255,0.05);
            border: 2px solid rgba(255,255,255,0.1);
            border-radius: 15px;
            color: white;
            font-size: 16px;
            outline: none;
            transition: border-color 0.3s;
        }

        .search-bar input:focus {
            border-color: #e94560;
        }

        .search-bar .search-icon {
